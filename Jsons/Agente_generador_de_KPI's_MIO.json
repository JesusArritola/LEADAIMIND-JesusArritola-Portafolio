    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Contar totales\nconst totalRestaurantes = items.length;\nconst restaurantesConTelefono = items.filter(item => item.json.Telefono && item.json.Telefono.trim() !== '').length;\nconst restaurantesConURL = items.filter(item => item.json.URl && item.json.URl.trim() !== '').length;\n\n// Calcular KPIs\nconst tasaContacto = totalRestaurantes > 0 ? (restaurantesConTelefono / totalRestaurantes) * 100 : 0;\nconst tasaURLDisponible = totalRestaurantes > 0 ? (restaurantesConURL / totalRestaurantes) * 100 : 0;\n\n// Agrupar por ciudad\nconst restaurantesPorCiudad = {};\nitems.forEach(item => {\n  const ciudad = item.json.Ciudad || 'Sin ciudad';\n  restaurantesPorCiudad[ciudad] = (restaurantesPorCiudad[ciudad] || 0) + 1;\n});\n\nreturn [{\n  json: {\n    TotalRestaurantes: totalRestaurantes,\n    RestaurantesConTelefono: restaurantesConTelefono,\n    RestaurantesConURL: restaurantesConURL,\n    TasaContacto: Math.round(tasaContacto * 100) / 100,\n    TasaURLDisponible: Math.round(tasaURLDisponible * 100) / 100,\n    RestaurantesPorCiudad: restaurantesPorCiudad\n  }\n}];"
      },
