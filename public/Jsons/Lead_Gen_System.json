    {
      "parameters": {
        "promptType": "define",
        "text": "=Esta es la informacion brindada por el usuario :\n{{ $json.query }}",
        "options": {
          "systemMessage": "=Eres un agente especializado en encontrar perfiles en linkedin, debes identificar estos parametros del mensaje que manda el usuario: joblitle y location\n\nTienes que ser capaz de extraer el JobTitle y location correctamente introducido por el usuario.\n\nDebes cambiar la query JobTitle-JobTitlelocation-location por los parámetros  que te da el usuario.\n\nEjemplo: JobTitle-editores de video location-peru\n\nAsegurate de devolver todos los valores de las personas encontradas por el escrapeo."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        4864,
        6752
      ],
      "id": "a6252883-0bb1-414b-aa61-c65d5be9e3aa",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~google-search-scraper/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "=apify_api_bqofhC6DRvjD2mcSDsdzPRrAfuyz2G3KBXzO"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"queries\": \"site:linkedin.com/in \\\"{{ $json.jobTitle }}\\\" {{ $json.location }}\",\n  \"resultsPerPage\": 20,\n  \"maxPagesPerQuery\": 1,\n  \"languageCode\": \"es\",\n  \"countryCode\": \"pe\"\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        5488,
        6752
      ],
      "id": "5b23322c-9d3d-4f61-b202-147d64a8411d",
      "name": "HTTP Request1"
    },
    {
      "parameters": {
        "jsCode": "// Get the output from the AI Agent\nconst output = $json.output;\n\n// Initialize variables\nlet jobTitle = null;\nlet location = null;\n\n// Try to parse the output as JSON first\ntry {\n  // Remove any markdown code blocks if present\n  let cleanOutput = output.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  \n  // Parse the JSON\n  const parsed = JSON.parse(cleanOutput);\n  \n  // Handle array format\n  if (Array.isArray(parsed) && parsed.length > 0) {\n    const data = parsed[0];\n    \n    // Extract JobTitle (handle both single value and array)\n    if (data.JobTitle) {\n      jobTitle = Array.isArray(data.JobTitle) ? data.JobTitle[0] : data.JobTitle;\n      // Remove + signs and clean up\n      jobTitle = jobTitle.replace(/\\+/g, ' ').trim();\n    }\n    \n    // Extract location from JobTitlelocation (handle both single value and array)\n    if (data.JobTitlelocation) {\n      location = Array.isArray(data.JobTitlelocation) ? data.JobTitlelocation[0] : data.JobTitlelocation;\n      // Remove + signs and clean up\n      location = location.replace(/\\+/g, ' ').trim();\n    }\n  }\n} catch (e) {\n  // If JSON parsing fails, try the original regex pattern\n  const match = output.match(/Jobtitle-(.*?)location-(.*)/i);\n  \n  if (match) {\n    jobTitle = match[1].trim();\n    location = match[2].trim();\n  }\n}\n\nreturn {\n  jobTitle,\n  location\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5232,
        6752
      ],
      "id": "cbafddf2-c0aa-46b7-b608-173f6173efdc",
      "name": "Limpiar"
