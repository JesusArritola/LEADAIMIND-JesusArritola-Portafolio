    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst jobTitle = ($('Limpiar').first().json.jobTitle || '').toLowerCase();\nconst location = ($('Limpiar').first().json.location || '').toLowerCase();\n\n// Extraer los resultados orgánicos del HTTP Request\nconst organicResults = items[0].json.organicResults || [];\n\n// Filtrar solo perfiles de LinkedIn que coincidan con el título y ubicación\nconst filteredResults = organicResults.filter(result => {\n  const hasLinkedInUrl = result.url && result.url.includes('linkedin.com/in/');\n  \n  if (!hasLinkedInUrl) return false;\n  \n  // Verificar si el perfil tiene información personal\n  const personalInfo = result.personalInfo || {};\n  const profileJobTitle = (personalInfo.jobTitle || '').toLowerCase();\n  const profileLocation = (personalInfo.location || '').toLowerCase();\n  \n  // Verificar coincidencia de título y ubicación\n  const titleMatch = profileJobTitle.includes(jobTitle) || jobTitle.includes(profileJobTitle);\n  const locationMatch = profileLocation.includes(location) || location.includes(profileLocation);\n  \n  return titleMatch && locationMatch;\n});\n\n// Retornar solo las URLs de los perfiles filtrados\nreturn filteredResults.map(result => ({\n  url: result.url,\n  title: result.title,\n  jobTitle: result.personalInfo?.jobTitle || '',\n  location: result.personalInfo?.location || '',\n  company: result.personalInfo?.companyName || ''\n}));"
      },
