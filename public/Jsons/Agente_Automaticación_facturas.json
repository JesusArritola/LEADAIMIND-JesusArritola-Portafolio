    {
      "parameters": {
        "jsCode": "// 1. Usar $input.all() para acceder a TODOS los datos que llegan al nodo\nconst allInputs = $input.all();\n\n// 2. DEBUG: Ver qué datos llegan (opcional, quitar después)\nconsole.log(\"DEBUG - Número de inputs:\", allInputs.length);\nallInputs.forEach((input, idx) => {\n  console.log(`Input ${idx} keys:`, Object.keys(input.json));\n  console.log(`Input ${idx} has chat.id?:`, !!input.json.message?.chat?.id);\n});\n\n// 3. Buscar el item que viene del nodo de análisis (OpenAI o Gemini)\nconst analyzeItem = allInputs.find(item => \n  item.json['0']?.content?.[0]?.text || item.json.content?.parts?.[0]?.text\n);\nconst raw = analyzeItem?.json['0']?.content?.[0]?.text ?? analyzeItem?.json.content?.parts?.[0]?.text ?? \"\";\n\nif (!raw) {\n  return { json: { _error: \"No llegó contenido desde el nodo de análisis de imagen.\" } };\n}\n\n// 4. Limpieza del texto para obtener solo el JSON válido\nconst m = raw.match(/```(?:json)?\\s*([\\s\\S]*?)\\s*```/i);\nlet body = (m ? m[1] : raw).trim();\nbody = body.replace(/,\\s*([}\\]])/g, \"$1\").replace(/\\r/g, \"\");\n\nlet obj;\ntry {\n  obj = JSON.parse(body);\n} catch (e) {\n  return { json: { _error: \"JSON inválido tras limpiar\", _raw: raw, _clean: body } };\n}\n\n// 5. Traer el link del nodo \"Subir Imagen\"\nconst uploadItem = allInputs.find(item => item.json.webContentLink);\nconst imagen = uploadItem?.json.webContentLink ?? null;\n\n// 6. CORRECCIÓN: Usar $items() para obtener chat_id directamente del nodo Telegram\nlet chatId = null;\ntry {\n  const telegramItems = $items('Telegram');\n  if (telegramItems && telegramItems.length > 0) {\n    chatId = telegramItems[0].json.message?.chat?.id ?? null;\n  }\n} catch (e) {\n  console.log(\"Error obteniendo chat_id desde Telegram:\", e.message);\n  // Fallback: buscar en allInputs\n  const telegramItem = allInputs.find(item => item.json.message?.chat?.id);\n  chatId = telegramItem?.json.message?.chat?.id ?? null;\n}\n\n// 7. DEBUG del chatId encontrado\nconsole.log(\"DEBUG - chatId encontrado:\", chatId);\n\n// 8. Retornar el JSON final\nreturn {\n  json: {\n    fecha: obj.fecha,\n    hora: obj.hora,\n    entidad: obj.entidad,\n    tipo_documento: obj.tipo_documento,\n    numero_documento: String(obj.numero_documento ?? \"\"),\n    oficina: String(obj.oficina ?? \"\"),\n    terminal: String(obj.terminal ?? \"\"),\n    usuario: obj.usuario,\n    metodo_pago: obj.metodo_pago,\n    numero_cuenta: String(obj.numero_cuenta ?? \"\"),\n    valor_efectivo: Number(obj.valor_efectivo ?? 0),\n    valor_cheque: Number(obj.valor_cheque ?? 0),\n    valor_total: Number(obj.valor_total ?? ((Number(obj.valor_efectivo ?? 0) + Number(obj.valor_cheque ?? 0))))/100,\n    costo_transaccion: Number(obj.costo_transaccion ?? 0),\n    numero_transaccion: String(obj.numero_transaccion ?? \"\"),\n    resultado: obj.resultado,\n    imagen: imagen,\n    chat_id: chatId\n  }\n};"
      },
