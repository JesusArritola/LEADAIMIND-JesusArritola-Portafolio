        "modelId": {
          "__rl": true,
          "value": "models/veo-3.0-generate-001",
          "mode": "list",
          "cachedResultName": "models/veo-3.0-generate-001"
        },
        "prompt": "=El video comienza con una toma media del avatar descrito a continuación.\nTiene un fondo marrón detrás, con relámpagos sutiles que aparecen y desaparecen lentamente en el fondo, pero están desenfocados para no llamar la atención.\n\nAvatar:\n{{ $json.Descripcion }}\n\nElla dice lo siguiente:\n\n{{ $json.Framing }}",
